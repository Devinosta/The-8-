<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Lending Services</title>
    <style>
        :root {
            --primary: #2c3e50;
            --accent: #27ae60;
            --light: #ecf0f1;
        }
        body { font-family: 'Segoe UI', sans-serif; margin: 0; color: #333; line-height: 1.6; }
        header { background: var(--primary); color: white; padding: 2rem; text-align: center; }
        .container { max-width: 800px; margin: auto; padding: 20px; }
        .calc-box { background: var(--light); padding: 25px; border-radius: 10px; border-left: 5px solid var(--accent); }
        input { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ccc; border-radius: 5px; }
        .btn { background: var(--accent); color: white; border: none; padding: 12px 20px; cursor: pointer; width: 100%; font-size: 1.1rem; border-radius: 5px; }
        .btn:hover { background: #219150; }
        #result { margin-top: 20px; font-weight: bold; font-size: 1.2rem; color: var(--primary); }
    </style>
</head>
<body>

<header>
    <h1>Fast & Flexible Lending</h1>
    <p>Your partner in financial growth</p>
</header>

<div class="container">
    <h2>Estimate Your Loan</h2>
    <div class="calc-box">
        <label>Loan Amount (₱)</label>
        <input type="number" id="amount" placeholder="Enter amount (e.g. 5000)">
        
        <button class="btn" onclick="calculate()">Calculate Repayment</button>
        <div id="result"></div>
    </div>

    <h3>Why Choose Us?</h3>
    <ul>
        <li><strong>Quick Approval:</strong> Simple requirements and fast processing.</li>
        <li><strong>Transparent Terms:</strong> No hidden charges; see your total before you borrow.</li>
        <li><strong>Professional Support:</strong> Dedicated assistance for your financial needs.</li>
    </ul>
</div>

<script>
    function calculate() {
        const amount = document.getElementById('amount').value;
        if(amount > 0) {
            // Using a standard 8% monthly calculation for the estimate
            const total = amount * 1.08;
            document.getElementById('result').innerHTML = 
                "Total Repayment (1 Month): ₱" + total.toLocaleString();
        } else {
            document.getElementById('result').innerHTML = "Please enter a valid amount.";
        }
    }
</script>

</body>
</html>
